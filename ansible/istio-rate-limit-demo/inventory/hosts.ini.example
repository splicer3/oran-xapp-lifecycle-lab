[hypervisor]
lab-hypervisor ansible_host=YOUR_HYPERVISOR_IP ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/id_rsa

[k3s_master]
master01 ansible_host=YOUR_MASTER_HOSTONLY_IP ansible_user=vagrant ansible_ssh_private_key_file=~/.ssh/id_rsa ansible_ssh_common_args='-o ProxyCommand="ssh -W %h:%p ubuntu@YOUR_HYPERVISOR_IP"'

[k3s_workers]
worker01 ansible_host=YOUR_WORKER_HOSTONLY_IP ansible_user=vagrant ansible_ssh_private_key_file=~/.ssh/id_rsa ansible_ssh_common_args='-o ProxyCommand="ssh -W %h:%p ubuntu@YOUR_HYPERVISOR_IP"'

[k3s_cluster:children]
k3s_master
k3s_workers
