apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: demo-ingress
  namespace: {{ demo_namespace }}
spec:
  ingressClassName: {{ ingress_class_name | default('nginx') }}
  rules:
    - host: {{ demo_host }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: demo-nginx-svc
                port:
                  number: 80
